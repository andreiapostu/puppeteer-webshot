  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^5.1.0",

{
  "name": "puppeteer-webshot",
  "version": "3.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "puppeteer",
    "screenshot",
    "to",
    "pdf",
    "png",
    "jpeg",
    "jpg",
    "render",
    "renderer",
    "ejs",
    "web",
    "webshot",
    "metadata"
  ],
  "author": "Andrei Apostu <andrei@aapostu.com>",
  "license": "MIT",
  "description": "A library for rendering web content into images or PDFs using Puppeteer. Supports both static and dynamic pages, with EJS integration for customizable templates and data-driven rendering.",
  "repository": {
    "type": "git",
    "url": "https://github.com/andreiapostu/puppeteer-webshot.git"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "exif-reader": "^2.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.22.2",
    "sharp": "^0.34.4"
  }
}
